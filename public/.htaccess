# ---------------------------------------------------------------
# HTTPS redirect
# ---------------------------------------------------------------
RewriteEngine On
RewriteCond %{HTTPS} off
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# ---------------------------------------------------------------
# Security headers
# ---------------------------------------------------------------
<IfModule mod_headers.c>
  # Prevent clickjacking
  Header always set X-Frame-Options "DENY"

  # Prevent MIME-type sniffing
  Header always set X-Content-Type-Options "nosniff"

  # Control referrer information sent to external sites
  Header always set Referrer-Policy "strict-origin-when-cross-origin"

  # Restrict browser features
  Header always set Permissions-Policy "geolocation=(), microphone=(), camera=(), payment=(), usb=(), interest-cohort=()"

  # Force HTTPS for 1 year (only active once HTTPS redirect above is confirmed working)
  Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"

  # Content Security Policy
  # - unsafe-inline required for: GA inline script in index.html + Framer Motion inline styles
  # - fonts.googleapis.com / fonts.gstatic.com for Google Fonts via CSS @import
  # - formspree.io for form submissions
  # - googletagmanager.com / google-analytics.com for GA4
  Header always set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' https://www.googletagmanager.com https://www.google-analytics.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https:; connect-src 'self' https://formspree.io https://www.google-analytics.com https://www.googletagmanager.com; object-src 'none'; base-uri 'self'; frame-ancestors 'none'; upgrade-insecure-requests"

  # Remove server info from responses
  Header always unset X-Powered-By
  Header always unset Server
</IfModule>

# ---------------------------------------------------------------
# Correct MIME types
# ---------------------------------------------------------------
<IfModule mod_mime.c>
  AddType image/webp .webp
  AddType image/svg+xml .svg
</IfModule>

# ---------------------------------------------------------------
# Caching — long cache for hashed assets, no cache for HTML
# ---------------------------------------------------------------
<IfModule mod_expires.c>
  ExpiresActive On

  # HTML — always revalidate
  ExpiresByType text/html "access plus 0 seconds"

  # Hashed assets — cache 1 year
  ExpiresByType application/javascript "access plus 1 year"
  ExpiresByType text/css "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType font/woff2 "access plus 1 year"
</IfModule>

# ---------------------------------------------------------------
# Gzip compression
# ---------------------------------------------------------------
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json image/svg+xml
</IfModule>

# ---------------------------------------------------------------
# SPA fallback — serve index.html for any unmatched path
# (catches any route not pre-rendered as its own directory)
# ---------------------------------------------------------------
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule ^ index.html [L]
</IfModule>
